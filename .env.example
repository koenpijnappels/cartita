# Neon Postgres connection string — stores first-party usage signals
# (events + ideas/suggestions). Server-only; never expose to the browser
# (no NEXT_PUBLIC_ prefix). Get it from the Neon dashboard:
# Connect → "Connection string" (the pooled one, includes ?sslmode=require).
#
# Copy this file to `.env.local` and fill in your own value. When unset, the
# app still runs and the analytics/suggestion endpoints simply no-op.
DATABASE_URL=

# ── Donations (Ko-fi) ───────────────────────────────────────────────────────
# Optional, calm "support the creator" flow shown only after positive feedback,
# plus a subtle "Apoyar Cartita" link in the start-screen footer. All public
# client-side values, hence the NEXT_PUBLIC_ prefix (no secrets here).
#
# Master switch: anything other than "true" hides ALL donation UI.
NEXT_PUBLIC_DONATIONS_ENABLED=true
#
# Per-amount Ko-fi links. Any that are left blank are simply hidden (no broken
# buttons). If all three are blank but the profile URL below is set, a single
# "Apoyar en Ko-fi" button is shown instead.
NEXT_PUBLIC_KOFI_COFFEE_URL=
NEXT_PUBLIC_KOFI_WINE_URL=
NEXT_PUBLIC_KOFI_COCKTAIL_URL=
#
# Generic Ko-fi profile page — used by the footer link and the single-button
# fallback. If no Ko-fi URLs are set at all, the donation prompt and footer
# link are hidden entirely.
NEXT_PUBLIC_KOFI_PROFILE_URL=
